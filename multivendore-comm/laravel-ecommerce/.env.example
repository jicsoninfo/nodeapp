APP_NAME="Marketplace SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ecommerce_saas
DB_USERNAME=root
DB_PASSWORD=

# Read replica (for heavy reads)
DB_READ_HOST=127.0.0.1
DB_READ_PORT=3306

# Cache & Sessions
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Queues
QUEUE_CONNECTION=redis
HORIZON_PREFIX=marketplace

# Redis
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Mail
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@marketplace.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher / Broadcasting
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Razorpay
RAZORPAY_KEY=
RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Algolia Search
SCOUT_DRIVER=algolia
ALGOLIA_APP_ID=
ALGOLIA_SECRET=

# Twilio SMS
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Firebase (Push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_SERVER_KEY=

# Commission & Platform
PLATFORM_COMMISSION_DEFAULT=15.00
PLATFORM_CURRENCY=USD
PLATFORM_TIMEZONE=UTC

# Rate Limiting
API_RATE_LIMIT=60
API_RATE_LIMIT_PER_MINUTE=60

# Feature Flags
FEATURE_MULTI_CURRENCY=true
FEATURE_LIVE_CHAT=true
FEATURE_AI_RECOMMENDATIONS=false
